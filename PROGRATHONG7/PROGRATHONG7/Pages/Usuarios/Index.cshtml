@page
@model PROGRATHONG7.Pages.Usuarios.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div style="max-width:700px;margin:40px auto;background:white;padding:30px;border-radius:15px;box-shadow:0 0 15px rgba(255,105,180,0.3);">

    <h1 style="text-align:center;color:#d63384;margin-bottom:30px;">👤 Usuarios</h1>

    <form method="post">
        @Html.AntiForgeryToken()
        <input asp-for="NuevoUsuario.Nombre" placeholder="Nombre completo" required style="width:100%;padding:10px;margin-bottom:10px;border-radius:8px;border:1px solid #ccc;" />
        <input asp-for="NuevoUsuario.Tipo" placeholder="Estudiante / Profesor" required style="width:100%;padding:10px;margin-bottom:10px;border-radius:8px;border:1px solid #ccc;" />
        <input asp-for="NuevoUsuario.Correo" placeholder="Correo electrónico" required style="width:100%;padding:10px;margin-bottom:10px;border-radius:8px;border:1px solid #ccc;" />

        <button type="submit" style="width:100%;background-color:#ff69b4;color:white;border:none;padding:12px;border-radius:8px;font-size:16px;cursor:pointer;">Agregar Usuario</button>
    </form>

    <table style="width:100%;margin-top:30px;border-collapse:collapse;">
        <tr style="background-color:#ffb6c1;">
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Correo</th>
        </tr>
        @foreach (var u in Model.ListaUsuarios)
        {
            <tr>
                <td>@u.Nombre</td>
                <td>@u.Tipo</td>
                <td>@u.Correo</td>
            </tr>
        }
    </table>
</div>